<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/xml_create_task_title"
            android:textColor="@color/xml_text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/closeCreateTaskButton"
            style="@style/Widget.Material3.Button.IconButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:icon="@android:drawable/ic_menu_close_clear_cancel"
            app:iconTint="@color/xml_text_secondary" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/xml_task_name"
        android:textColor="@color/xml_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:boxBackgroundColor="@color/xml_surface_muted"
        app:boxStrokeColor="@color/xml_border">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/createTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/xml_task_title" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/xml_task_description"
        android:textColor="@color/xml_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:boxBackgroundColor="@color/xml_surface_muted"
        app:boxStrokeColor="@color/xml_border">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/createTaskDescription"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:minLines="4"
            android:hint="@string/xml_task_description" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/xml_task_priority"
        android:textColor="@color/xml_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:boxBackgroundColor="@color/xml_surface_muted"
        app:boxStrokeColor="@color/xml_border">

        <AutoCompleteTextView
            android:id="@+id/createTaskPriority"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:hint="@string/xml_task_priority"
            android:text="@string/xml_task_priority_low" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/xml_task_completion"
        android:textColor="@color/xml_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:boxBackgroundColor="@color/xml_surface_muted"
        app:boxStrokeColor="@color/xml_border">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/createTaskCompletion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:hint="0"
            android:text="0" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/xml_task_status"
        android:textColor="@color/xml_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:boxBackgroundColor="@color/xml_surface_muted"
        app:boxStrokeColor="@color/xml_border">

        <AutoCompleteTextView
            android:id="@+id/createTaskStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:hint="@string/xml_task_status"
            android:text="@string/xml_task_status_not_started" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/xml_assign_to"
        android:textColor="@color/xml_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        app:boxBackgroundColor="@color/xml_surface_muted"
        app:boxStrokeColor="@color/xml_border">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/createTaskSearchCollaborators"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/xml_search_collaborators" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:id="@+id/createTaskCollaboratorsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:padding="8dp">

        <!-- Placeholder chips serão adicionados dinamicamente via código -->
        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="👤 Placeholder"
            android:textColor="@color/xml_text_primary"
            app:chipBackgroundColor="@color/xml_surface_muted"
            app:closeIconEnabled="false"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/saveTaskButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/xml_save_task"
        android:textColor="@color/white"
        android:textStyle="bold"
        app:backgroundTint="@color/xml_primary"
        app:cornerRadius="10dp" />

</LinearLayout>

